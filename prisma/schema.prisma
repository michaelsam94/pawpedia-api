generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Favorite {
  id        String   @id
  deviceId  String
  breedId   String
  breedName String
  imageUrl  String?
  createdAt DateTime @default(now())

  @@unique([deviceId, breedId])
  @@index([deviceId])
}
